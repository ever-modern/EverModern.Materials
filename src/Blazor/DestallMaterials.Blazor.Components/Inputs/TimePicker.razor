@using System.Globalization

@inherits BaseInput<TimeOnly>

<div class="time-picker @(HasError ? "errored" : "") @Class" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="time-picker-label">@Label</label>
    }
    <input type="time"
           class="time-picker-field"
           value="@CurrentValue"
           @onchange="OnTimeChanged"
           step="60" />
    @if (HasError)
    {
        <span class="time-picker-error">Invalid time</span>
    }
</div>

@code {
    [Parameter]
    public TimeSpan Time { get; set; }

    [Parameter]
    public CultureInfo Culture { get; set; } = CultureInfo.CurrentCulture;

    [Parameter]
    public string Style { get; set; } = "";

    private string CurrentValue
    {
        get
        {
            var timeOnly = TimeOnly.FromTimeSpan(Time);
            return timeOnly.ToString("HH:mm");
        }
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (!string.IsNullOrEmpty(value) && TimeOnly.TryParse(value, out var parsed))
        {
            var newTime = parsed;
            if (TimeOnly.FromTimeSpan(Time) != newTime)
            {
                OnValueChanged?.Invoke(newTime);
                StateHasChanged();
            }
        }
    }
}
