@using DestallMaterials.Blazor.Components.Common
@using DestallMaterials.Blazor.Components.Services.UI

@inherits DisposableComponent

@inject IUiManipulator ui
@inject IGlobalClickCatcher globalClickCatcher


<input type="text"
       @oninput="(ev) => OnInput((string)(ev.Value ?? string.Empty))"
       @onclick="OnClick"
       @onfocus="OnClick"
       value="@FormatMask(Value)"
       class="@($"masked-input {CssClass}")"
       id="@_inputId"
       style="@CssStyle"
       @onblur="(_) => EnsureInputContentAsync(FormatMask(Value))" />

