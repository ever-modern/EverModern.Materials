@using System.Threading
@using DestallMaterials.Blazor.Components.Common
@using DestallMaterials.Blazor.Components.Services.UI
@typeparam TItem
@inherits DisposableComponent

@inject IGlobalClickCatcher globalClickCatcher;

<div class="autocomplete @(Error ? "errored" : "") @Class"
     @onclick="OpenDropdown"
     @onmouseout="() => MouseIn = false"
     @onmouseover="() => MouseIn = true"
     @onmouseleave="() => MouseIn = false"
     @onmouseenter="() => MouseIn = true">

    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="autocomplete-label">@Label</label>
    }
    <div class="autocomplete-input-wrapper">
        <input type="text"
               class="autocomplete-field"
               @bind="SearchText"
               @bind:event="oninput"
               @onfocus="OnFocus"
               @onblur="OnBlurAsync"
               disabled="@Disabled"
               placeholder="@Label" />
        @if (Clearable && Value != null)
        {
            <button type="button" class="autocomplete-clear" @onclick="Clear">×</button>
        }
    </div>
    @if (_showDropdown && _items != null && _items.Any())
    {
        <ul class="autocomplete-dropdown" style="list-style-type: none">
            @{
                var itemsList = _items.Take(MaxItems).ToList();
                for (int i = 0; i < itemsList.Count; i++)
                {
                    var item = itemsList[i];
                    var index = i;
                    var highlightClass = index == _highlightedIndex ? "highlighted" : "";
                    <li class="autocomplete-item @highlightClass" @onclick="() => SelectItem(item)">
                        @if (ItemTemplate != null)
                        {
                            @ItemTemplate(item)
                        }
                        else
                        {
                            @ToStringFunc(item)
                        }
                    </li>
                }
            }
        </ul>
    }
    @if (Error)
    {
        <span class="autocomplete-error">@ErrorText</span>
    }
</div>

@code {

    [Parameter]
    [EditorRequired]
    public Func<string, CancellationToken, Task<IReadOnlyList<TItem>>> SearchFunc { get; set; }

    [Parameter]
    public Func<TItem, string> ToStringFunc { get; set; } = item => item?.ToString() ?? "";

    [Parameter]
    public TItem? Value { get; set; }

    [Parameter]
    [EditorRequired]
    public Action<TItem?> ValueChanged { get; set; }

    [Parameter]
    public string Label { get; set; } = "";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Clearable { get; set; }

    [Parameter]
    public Action? OnClearButtonClick { get; set; }

    [Parameter]
    public string Class { get; set; } = "";

    [Parameter]
    public bool Error { get; set; }

    [Parameter]
    public string ErrorText { get; set; } = "";

    [Parameter]
    public RenderFragment<TItem>? ItemTemplate { get; set; }

    [Parameter]
    public RenderFragment<TItem>? ItemSelectedTemplate { get; set; }

    [Parameter]
    public int MaxItems { get; set; } = 50;

    protected bool MouseIn { get; set; }

    private string _searchText = "";
    private bool _showDropdown;
    private IReadOnlyList<TItem> _items = [];
    private CancellationTokenSource _searchCts = new();
    private int _highlightedIndex = -1;

    private string SearchText
    {
        get => _searchText;
        set
        {
            _searchText = value;
            _ = PerformSearchAsync(value);
        }
    }

    protected override void OnParametersSet()
    {
        base.OnParametersSet();
        if (Value != null)
        {
            _searchText = ToStringFunc(Value);
        }
    }

    private async void OpenDropdown()
    {
        if (Disabled)
            return;

        // If there are no items and search text is empty, perform an initial search
        if (!_items.Any() && string.IsNullOrWhiteSpace(_searchText))
        {
            await PerformSearchAsync("");
        }

        // Open dropdown if we have items
        if (_items.Any())
        {
            _showDropdown = true;
            StateHasChanged();
        }
    }

    private async Task HandleKeyPress(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs keyEvent)
    {
        if (!_showDropdown || !_items.Any())
            return;

        var itemsList = _items.Take(MaxItems).ToList();


    }

    private async Task PerformSearchAsync(string searchText)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        if (string.IsNullOrWhiteSpace(searchText))
        {
            _items = [];
            _showDropdown = false;
            _highlightedIndex = -1;
            StateHasChanged();
            return;
        }

        try
        {
            var results = await SearchFunc(searchText, _searchCts.Token);
            _items = results ?? [];
            _showDropdown = _items.Any();
            _highlightedIndex = -1;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    private void OnFocus()
    {
        if (_items.Any())
        {
            _showDropdown = true;
        }
    }

    private async Task OnBlurAsync()
    {
        await Task.Delay(200); // Delay to allow click on dropdown item
        _showDropdown = false;
        _highlightedIndex = -1;
        StateHasChanged();
    }

    private void SelectItem(TItem item)
    {
        Value = item;
        _searchText = ToStringFunc(item);
        _showDropdown = false;
        _highlightedIndex = -1;
        ValueChanged?.Invoke(item);
        StateHasChanged();
    }

    private void Clear()
    {
        Value = default;
        _searchText = "";
        _showDropdown = false;
        _highlightedIndex = -1;
        OnClearButtonClick?.Invoke();
        ValueChanged?.Invoke(default);
        StateHasChanged();
    }

    protected override void BeforeDispose()
    {
        base.BeforeDispose();
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender)
        {
            BindToLifetime(globalClickCatcher.OnMouseClicked((_, _) =>
            {
                if (MouseIn)
                {
                    _showDropdown = false;
                }
            }), globalClickCatcher.OnKeyPressed((args, _) =>
            {
                if (_showDropdown)
                {
                    var key = args.Key;

                    _highlightedIndex = key switch
                    {
                        "ArrowDown" => (_highlightedIndex + 1) % _items.Count,
                        "ArrowUp" => _highlightedIndex <= 0 ? _items.Count - 1 : _highlightedIndex - 1,
                        _ => _highlightedIndex
                    };

                    if (key == "Enter")
                    {
                        SelectItem(_items[_highlightedIndex]);
                    }

                    StateHasChanged();
                }
            }));
        }
    }
}
