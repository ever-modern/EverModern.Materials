@using System.Threading
@using DestallMaterials.Blazor.Components.Common
@using DestallMaterials.Blazor.Components.Services.UI
@typeparam TItem
@inherits DisposableComponent

@inject IGlobalClickCatcher globalClickCatcher;

<div class="autocomplete @(Error ? "errored" : "") @Class"
     @onclick="() => { if (_overClearButton is false) OpenDropdown(); }"
     @onmouseout="() => MouseIn = false"
     @onmouseover="() => MouseIn = true"
     @onmouseleave="() => MouseIn = false"
     @onmouseenter="() => MouseIn = true"
     @onfocus="() => _hasFocus = true"
     @onblur="() => _hasFocus = false">

    @{
        var (labelStyle, labelText) = string.IsNullOrWhiteSpace(Label) ? ("visibility: hidden", "---") : ("", Label);
    }

    <label class="autocomplete-label" style="@labelStyle">@labelText</label>

    <div class="autocomplete-input-wrapper">
        <input type="text"
               class="autocomplete-field"
               @oninput="@(async (s) =>
               {
                   _searchText = (string)(s.Value ?? "");
                   _visibleText = _searchText;
                   await PerformSearchAsync(_searchText);
               })"
               @onfocus="OnFocus"
               @onblur="OnBlurAsync"
               disabled="@Disabled"
               placeholder="@(Disabled ? "" : Placeholder)"
               value="@_visibleText"
               style="width: stretch" />
        @if (!Disabled && Clearable && (string.IsNullOrWhiteSpace(Text) == false))
        {
            <button type="button" class="autocomplete-clear" @onclick="Clear"
                    @onmouseout="() => _overClearButton = false"
                    @onmouseover="() => _overClearButton = true"
                    @onmouseleave="() => _overClearButton = false"
                    @onmouseenter="() => _overClearButton = true">
                ×
            </button>
        }
    </div>
    @if (_showDropdown && Options != null && Options.Any())
    {
        <ul class="autocomplete-dropdown" style="list-style-type: none">
            @{
                var itemsList = Options.Take(MaxItems).ToList();
                for (int i = 0; i < itemsList.Count; i++)
                {
                    var item = itemsList[i];
                    var index = i;
                    var highlightClass = index == _highlightedIndex ? "highlighted" : "";

                    Action setHoveredItem = () => { if (_hoveredItem?.Equals(item) != true) { _hoveredItem = item; } };
                    Action unsetHoveredItem = () => { if (_hoveredItem?.Equals(item) == true) { _hoveredItem = default; } };

                    <li class="autocomplete-item @highlightClass"
                        @onmouseout="unsetHoveredItem"
                        @onmouseover="setHoveredItem"
                        @onmouseleave="unsetHoveredItem"
                        @onmouseenter="setHoveredItem">

                        @if (ItemTemplate is not null)
                        {
                            @ItemTemplate(item)
                        }
                        else
                        {
                            @ToStringFunc(item)
                        }
                    </li>
                }
            }
        </ul>
    }
    @if (Error)
    {
        <span class="autocomplete-error">@ErrorText</span>
    }
</div>

@code {

    [Parameter]
    [EditorRequired]
    public Func<string, CancellationToken, Task<IReadOnlyList<TItem>>> SearchFunc { get; set; }

    [Parameter]
    public Func<TItem, string> ToStringFunc { get; set; } = item => item?.ToString() ?? "";

    [Parameter]
    public string? Text { get; set; }

    [Parameter]
    [EditorRequired]
    public Action<TItem?> ValueChanged { get; set; }

    [Parameter]
    public string Label { get; set; } = "";

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public bool Clearable { get; set; }

    [Parameter]
    public Action? OnClearButtonClick { get; set; }

    [Parameter]
    public string Class { get; set; } = "";

    [Parameter]
    public bool Error { get; set; }

    [Parameter]
    public string ErrorText { get; set; } = "";

    [Parameter]
    public RenderFragment<TItem>? ItemTemplate { get; set; }

    [Parameter]
    public RenderFragment<TItem>? ItemSelectedTemplate { get; set; }

    [Parameter]
    public int MaxItems { get; set; } = 50;

    [Parameter]
    public string? Placeholder { get; set; }

    protected bool MouseIn { get; set; }

    private string _searchText = "";
    private bool _showDropdown;
    (string SearchText, IReadOnlyList<TItem> Items) _lastSearchResult = default;
    private IReadOnlyList<TItem> Options => _lastSearchResult.Items ?? [];
    private CancellationTokenSource _searchCts = new();
    private int _highlightedIndex = -1;
    private TItem? _hoveredItem;
    private string _visibleText = "";
    private bool _overClearButton = false;
    private bool _hasFocus = false;

    async void OpenDropdown()
    {
        if (Disabled)
            return;

        // If there are no items and search text is empty, perform an initial search
        if (!Options.Any())
        {
            await PerformSearchAsync("");
        }

        // Open dropdown if we have items
        if (Options.Any())
        {
            _showDropdown = true;
            StateHasChanged();
        }
    }

    void CloseDropdown()
    {
        _showDropdown = false;
    }

    async Task HandleKeyPress(Microsoft.AspNetCore.Components.Web.KeyboardEventArgs keyEvent)
    {
        if (!_showDropdown || !Options.Any())
            return;

        var itemsList = Options.Take(MaxItems).ToList();
    }

    async Task PerformSearchAsync(string searchText)
    {
        _searchCts?.Cancel();
        _searchCts = new CancellationTokenSource();

        if (searchText == _lastSearchResult.SearchText)
        {
            return;
        }

        try
        {
            var results = await SearchFunc(searchText, _searchCts.Token);
            _lastSearchResult = (searchText, results);
            _showDropdown = results.Any();
            _highlightedIndex = -1;
            StateHasChanged();
        }
        catch (TaskCanceledException)
        {
            // Ignore cancellation
        }
    }

    void OnFocus()
    {
        if (Options.Any())
        {
            _showDropdown = true;
        }
    }

    async Task OnBlurAsync()
    {
        await Task.Delay(200); // Delay to allow click on dropdown item
        CloseDropdown();
        _highlightedIndex = -1;
        StateHasChanged();
    }

    void SelectItem(TItem item)
    {
        Text = ToStringFunc(item);
        _searchText = ToStringFunc(item);
        _visibleText = _searchText;
        CloseDropdown();
        _highlightedIndex = -1;
        ValueChanged?.Invoke(item);
        StateHasChanged();
    }

    void Clear()
    {
        Text = "";
        _searchText = "";
        _visibleText = "";
        CloseDropdown();
        _highlightedIndex = -1;
        OnClearButtonClick?.Invoke();
        ValueChanged?.Invoke(default);
        StateHasChanged();
    }

    protected override void BeforeDispose()
    {
        base.BeforeDispose();
        _searchCts?.Cancel();
        _searchCts?.Dispose();
    }

    protected override async Task OnParametersSetAsync()
    {
        await base.OnParametersSetAsync();

        if (_lastSearchResult.SearchText is null)
        {
            var foundItems = await SearchFunc(_searchText, default);
            _lastSearchResult = (_searchText, foundItems);

        }
    }

    static readonly IReadOnlyList<string> _sensitiveKeys = "ArrowUp ArrowDown Enter".Split(" ");
    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);

        if (firstRender)
        {
            _searchText = Text ?? "";

            BindToLifetime(globalClickCatcher.OnMouseClicked((_, _) =>
            {
                if (_hoveredItem is not null)
                {
                    SelectItem(_hoveredItem);
                    _hoveredItem = default;
                }
                else if (MouseIn is false)
                {
                    CloseDropdown();
                }
            }), globalClickCatcher.OnKeyPressed((args, _) =>
            {
                var key = args.Key;
                if (_sensitiveKeys.Contains(key) is false || _hasFocus)
                {
                    return;
                }
                if (Options.Any())
                {
                    _showDropdown = true;

                    _highlightedIndex = key switch
                    {
                        "ArrowDown" => (_highlightedIndex + 1) % Options.Count,
                        "ArrowUp" => _highlightedIndex <= 0 ? Options.Count - 1 : _highlightedIndex - 1,
                        _ => _highlightedIndex
                    };

                    if (key == "Enter")
                    {
                        SelectItem(Options[_highlightedIndex]);
                    }

                    StateHasChanged();
                }
            }));
        }
    }
}
