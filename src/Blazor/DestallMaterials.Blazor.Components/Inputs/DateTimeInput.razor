@using System.Globalization

@inherits BaseInput<DateTime>

<div class="datetime-input base-input @(Disabled ? "disabled" : "") @(Error is not null ? "errored" : "") @CssClass">
    @if (PickDate && PickTime)
    {
        <!-- Show label only once when both are displayed -->
        @if (!string.IsNullOrEmpty(Label))
        {
            <label class="datetime-input-label">@Label</label>
        }
        <div class="datetime-input-controls">
            <DateInput Clearable="false"
                       OnValueChanged="d => _ = OnDateChanged(d)"
                       Value=Date
                       ValueNotSetText="Date"
                       Culture=Culture
                       CssClass="datetime-input-date"
                       Error="@Error" />
            <TimeInput Culture=Culture
                       CssClass="datetime-input-time"
                       OnValueChanged="t => _ = OnTimeChanged(t)"
                       Time="Time"
                       Error=@(Error) />
            <button type="button"
                    class="datetime-input-clear @(Date == default ? "hidden" : "")"
                    @onclick="ClearValue">
                ×
            </button>
        </div>
    }
    else if (PickDate)
    {
        <DateInput Clearable="true"
                   OnValueChanged="d => _ = OnDateChanged(d)"
                   Value=Date
                   ValueNotSetText="Date"
                   Culture=Culture
                   Label="@Label"
                   Error="@Error" />
    }
    else if (PickTime)
    {
        <TimeInput Culture=Culture
                   OnValueChanged="t => _ = OnTimeChanged(t)"
                   Time="Time"
                   Label="@Label"
                   Error=@(Error) />
    }
</div>

@code {

    [Parameter]
    public bool PickTime { get; set; } = true;

    [Parameter]
    public bool PickDate { get; set; } = true;

    [Parameter]
    public DateTime MinValue { get; set; } = new DateTime(2000, 1, 1);

    [Parameter]
    public CultureInfo Culture { get; set; } = System.Globalization.CultureInfo.CurrentCulture;

    protected override void OnParametersSet()
    {
        if (!PickDate && !PickTime)
        {
            throw new InvalidOperationException("At least either time or date should be pickable.");
        }

        base.OnParametersSet();
    }

    string ValueString => Value > new DateTime(2200, 01, 01) ? "∞" : Value.ToString();

    public TimeSpan Time
    {
        get => Value.TimeOfDay;
        internal set
        {
            var newValue = (Date).ToDateTime(TimeOnly.FromTimeSpan(value));
            _ = OnValueChangedAsync(newValue);
        }
    }

    public DateOnly Date
    {
        get => DateOnly.FromDateTime(Value);
        internal set
        {
            var newValue = (value).ToDateTime(TimeOnly.FromTimeSpan(Time));
            _ = OnValueChangedAsync(newValue);
        }
    }

    private async Task OnValueChangedAsync(DateTime newValue)
    {
        OnValueChanged?.Invoke(newValue);
        await Task.CompletedTask;
        StateHasChanged();
    }

    public DateTimeInput()
    {
        Value = DateTime.Now;
    }

    void ClearValue()
    {
        Value = default;
        _ = OnValueChangedAsync(default);
    }

    async Task OnDateChanged(DateOnly date)
    {
        var newValue = date.ToDateTime(TimeOnly.FromTimeSpan(Time));
        if (Value != newValue)
        {
            Value = newValue;
            await OnValueChangedAsync(newValue);
        }
    }

    async Task OnTimeChanged(TimeOnly time)
    {
        var newValue = Date.ToDateTime(time);
        if (Value != newValue)
        {
            Value = newValue;
            await OnValueChangedAsync(newValue);
        }
    }

    public DateTime WithTime(TimeOnly time) => Value.Date + time.ToTimeSpan();
    public DateTime WithDate(DateOnly date) => date.ToDateTime(default) + Value.TimeOfDay;
}