@using System.Globalization

@inherits BaseInput<TimeOnly>

<div class="time-picker @(HasError ? "errored" : "") @Class" style="@Style">
    @if (!string.IsNullOrEmpty(Label))
    {
        <label class="time-picker-label">@Label</label>
    }
    <input type="time"
           class="time-picker-field"
           value="@CurrentValue"
           @onchange="OnTimeChanged"
           step="60" />
    @if (HasError)
    {
        <span class="time-picker-error">Invalid time</span>
    }
</div>

@code {
    [Parameter]
    public TimeSpan Time { get; set; }

    [Parameter]
    public CultureInfo Culture { get; set; } = CultureInfo.CurrentCulture;

    [Parameter]
    public string Style { get; set; } = "";

    protected override void OnParametersSet()
    {
        // Sync TimeSpan parameter with TimeOnly Value
        if (Time != default)
        {
            Value = TimeOnly.FromTimeSpan(Time);
        }
        base.OnParametersSet();
    }

    private string CurrentValue
    {
        get
        {
            return Value != default ? Value.ToString("HH:mm") : TimeOnly.FromTimeSpan(Time).ToString("HH:mm");
        }
    }

    private void OnTimeChanged(ChangeEventArgs e)
    {
        var value = e.Value?.ToString();
        if (!string.IsNullOrEmpty(value) && TimeOnly.TryParse(value, out var parsed))
        {
            var newTime = parsed;
            if (Value != newTime)
            {
                Value = newTime;
                _ = OnValueChangedAsync(newTime);
            }
        }
    }

    private async Task OnValueChangedAsync(TimeOnly newValue)
    {
        OnValueChanged?.Invoke(newValue);
        await Task.CompletedTask;
        StateHasChanged();
    }
}
