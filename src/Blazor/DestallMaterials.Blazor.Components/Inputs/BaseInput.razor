@using DestallMaterials.Blazor.Components.Universal
@using Microsoft.AspNetCore.Components.Web
@typeparam TValue

@inherits DisposableComponent

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    [EditorRequired]
    public Action<TValue> OnValueChanged { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public Action OnBlur { get; set; } = () => { };

    [Parameter]
    public Action OnMouseIn { get; set; } = () => { };

    [Parameter]
    public Action OnMouseOut { get; set; } = () => { };

    [Parameter]
    public Action OnClickOutside { get; set; } = () => { };

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string Class { get; set; } = "";

    [Parameter]
    public string? Error { get; set; }

    protected virtual void OnValueSet(TValue newValue)
    {
    }

    protected void OnOuterClick(MouseEventArgs mouseEventArgs)
    {
        if (OnClickOutside != null)
        {
            OnClickOutside();
        }
    }
}
