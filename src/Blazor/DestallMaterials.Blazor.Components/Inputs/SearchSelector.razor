@using DestallMaterials.Blazor.Components.Containers
@typeparam TItem

@inherits BaseInput<TItem>

@{
    RenderFragment<TItem> itemTemplate = ItemTemplate ?? (row => @<text>@GetItemRepresentation(row)</text>);
}
<Autocomplete TItem="TItem"
              Label="@(Value is null ? "" : Label)"
              SearchFunc="async (filter, ct) => await GetItemsByFilter(filter, ct)"
              ToStringFunc="GetItemRepresentation"
              MaxItems="50"
              Text="@(Value is null ? "" : GetItemRepresentation(Value))"
              ValueChanged="OnValueSetInner"
              Disabled=Disabled
              Clearable=MayBeEmpty
              OnClearButtonClick="Clear"
              Class="@cssClass"
              Error="HasError"
              ErrorText=@Error
              ItemSelectedTemplate="itemTemplate"
              ItemTemplate="itemTemplate"
              Placeholder="@Label" />

@code {
    [Parameter]
    [EditorRequired]
    public Func<string, CancellationToken, Task<IReadOnlyList<TItem>>> GetItemsByFilter { get; set; }

    [Parameter]
    public Func<TItem, string> GetItemRepresentation { get; set; } = item => item?.ToString() ?? "";

    [Parameter]
    public int MaxItemsShown { get; set; }

    [Parameter]
    public Action OnClear { get; set; } = () => { };

    [Parameter]
    public bool MayBeEmpty { get; set; } = true;

    [Parameter]
    public RenderFragment<TItem> ItemTemplate { get; set; }

    public bool HasError => string.IsNullOrWhiteSpace(Error) == false;

    string cssClass => $"input search-selector-singular {Class}";

    void Clear()
    {
        Value = default;
        _ = OnValueChangedAsync(Value);
        OnClear();
    }

    void OnValueSetInner(TItem item)
    {
        Value = item;
        _ = OnValueChangedAsync(item);
    }

    private async Task OnValueChangedAsync(TItem newValue)
    {
        OnValueChanged?.Invoke(newValue);
        await Task.CompletedTask;
        StateHasChanged();
    }
}
