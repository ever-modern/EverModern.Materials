@using System.Globalization
@using EverModern.Blazor.Components.Common
@using Microsoft.AspNetCore.Components.Web

@typeparam TValue

@inherits DisposableComponent

@code {
    [Parameter]
    public string? Label { get; set; }

    [Parameter]
    public TValue? Value { get; set; }

    [Parameter]
    [EditorRequired]
    public Action<TValue> OnValueChanged { get; set; }

    [Parameter]
    public RenderFragment? ChildContent { get; set; }

    [Parameter]
    public Action OnBlur { get; set; } = () => { };

    [Parameter]
    public Action OnMouseIn { get; set; } = () => { };

    [Parameter]
    public Action OnMouseOut { get; set; } = () => { };

    [Parameter]
    public Action OnClickOutside { get; set; } = () => { };

    [Parameter]
    public bool Disabled { get; set; }

    [Parameter]
    public string CssClass { get; set; } = "";

    [Parameter]
    public string CssStyle { get; set; } = "";

    [Parameter]
    public string? Error { get; set; }

    [Parameter]
    public Action OnFocus { get; set; } = () => { };

    [Parameter]
    public Action OnClick { get; set; } = () => { };

    [Parameter]
    public CultureInfo Culture { get; set; } = CultureInfo.CurrentUICulture;

    public bool HasError => string.IsNullOrWhiteSpace(Error) == false;

    protected void OnOuterClick(MouseEventArgs mouseEventArgs)
    {
        if (OnClickOutside != null)
        {
            OnClickOutside();
        }
    }

    public string Id { get; } = Guid.NewGuid().ToString();
}
