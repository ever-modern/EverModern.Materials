@using EverModern.Blazor.Components.Containers

@using EverModern.Blazor.Components.Services.UI
@inherits LayoutComponentBase


@inject IGlobalClickInvoker clickInvoker

@* <p @onkeydown="e => clickInvoker.FireKeyClickEvent(new())" /> *@

<Container OnInnerClick="(e) => clickInvoker.FireGlobalMouseClickEvent(e)"
           OnKeyClicked="k => clickInvoker.FireKeyClickEvent(k)">

    @Body

    <div id="blazor-error-ui" data-nosnippet>
        An unhandled error has occurred.
        <a href="." class="reload">Reload</a>
        <span class="dismiss">🗙</span>
    </div>
</Container>

