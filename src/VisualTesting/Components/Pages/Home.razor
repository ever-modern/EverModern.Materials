@page "/"
@using DestallMaterials.Blazor.Components.Inputs
@using System.Globalization
@using DestallMaterials.Blazor.Components.Services.UI

@inject IGlobalClickInvoker clickInvoker

<PageTitle>Component Visual Testing</PageTitle>

<h1>DestallMaterials.Blazor.Components - Visual Testing</h1>

<div @onclick="(e) => clickInvoker.FireGlobalMouseClickEvent(e)"
     @onmousedown="(e) => clickInvoker.FireGlobalMouseClickEvent(e)"
     @onkeydown="e => clickInvoker.FireKeyClickEvent(e)">

    <!-- SearchSelectorSingular Component Tests -->
    <section style="border: 1px solid #ccc; padding: 15px; border-radius: 8px;">
        <h2>SearchSelectorSingular Component</h2>

        <div style="margin: 10px 0;">
            <h3>Basic Search Selector:</h3>
            <SearchSelector TItem="string"
                                    Label="Country"
                                    GetItemsByFilter="SearchCountries"
                                    GetItemRepresentation="item => item"
                                    OnValueChanged="v => SelectedCountry = v"
                                    Value="@SelectedCountry" />
            <p>Selected Country: <strong>@(SelectedCountry ?? "None")</strong></p>
        </div>

        <div style="margin: 10px 0;">
            <DateInput 
                Label="Event date"
                OnValueChanged="v => EventDate = v"
                Value="@EventDate"
                MinValue="new(2024,4,6)"
                MaxValue="DateOnly.FromDateTime(DateTime.Today)" />
            <p>Event date: <strong>@(EventDate == default ? "None" : EventDate)</strong></p>
        </div>

    </section>

</div>

@code {
    // Person class for testing
    public class Person
    {
        public string FirstName { get; set; } = "";
        public string LastName { get; set; } = "";
    }
    // Flag component values
    bool NotificationsEnabled { get; set; } = true;
    bool TermsAccepted { get; set; } = false;
    bool RequiredCheck { get; set; } = false;

    // StringInput values
    string FullName { get; set; } = "";
    string Email { get; set; } = "";

    // NumberInput values
    int Age { get; set; } = 25;
    decimal Price { get; set; } = 99.99m;
    int Quantity { get; set; } = 0;

    // DatePicker values
    DateOnly BirthDate { get; set; } = default;
    DateOnly EventDate { get; set; } = default;

    // DateTimeInput values
    DateTime Appointment { get; set; } = DateTime.Now.AddDays(7);
    DateTime MeetingDate { get; set; } = DateTime.Now;
    DateTime ReminderTime { get; set; } = DateTime.Now;

    // SearchSelectorSingular values
    string? SelectedCountry { get; set; }
    Person? SelectedPerson { get; set; }

    // SearchSelectorPlural values
    string[] SelectedSkills { get; set; } = Array.Empty<string>();
    string[] SelectedTechnologies { get; set; } = Array.Empty<string>();

    // Test data
    private readonly List<string> _countries = new()
    {
        "United States", "United Kingdom", "Germany", "France", "Italy", "Spain",
        "Canada", "Australia", "Japan", "China", "Brazil", "India", "Russia"
    };

    private readonly List<Person> _people = new()
    {
        new Person { FirstName = "John", LastName = "Doe" },
        new Person { FirstName = "Jane", LastName = "Smith" },
        new Person { FirstName = "Bob", LastName = "Johnson" },
        new Person { FirstName = "Alice", LastName = "Williams" },
        new Person { FirstName = "Charlie", LastName = "Brown" }
    };

    private readonly List<string> _skills = new()
    {
        "C#", "JavaScript", "Python", "Java", "TypeScript", "SQL",
        "HTML", "CSS", "React", "Angular", "Vue.js", "Node.js"
    };

    private readonly List<string> _technologies = new()
    {
        ".NET", "ASP.NET Core", "Blazor", "Entity Framework", "Docker",
        "Kubernetes", "Azure", "AWS", "Git", "CI/CD", "Microservices"
    };

    private Task<IReadOnlyList<string>> SearchCountries(string filter, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(filter)
            ? _countries
            : _countries.Where(c => c.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        return Task.FromResult<IReadOnlyList<string>>(filtered);
    }

    private Task<IReadOnlyList<Person>> SearchPeople(string filter, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(filter)
            ? _people
            : _people.Where(p =>
                p.FirstName.Contains(filter, StringComparison.OrdinalIgnoreCase) ||
                p.LastName.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        return Task.FromResult<IReadOnlyList<Person>>(filtered);
    }

    private Task<IReadOnlyList<string>> SearchSkills(string filter, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(filter)
            ? _skills
            : _skills.Where(s => s.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        return Task.FromResult<IReadOnlyList<string>>(filtered);
    }

    private Task<IReadOnlyList<string>> SearchTechnologies(string filter, CancellationToken ct)
    {
        var filtered = string.IsNullOrWhiteSpace(filter)
            ? _technologies
            : _technologies.Where(t => t.Contains(filter, StringComparison.OrdinalIgnoreCase)).ToList();
        return Task.FromResult<IReadOnlyList<string>>(filtered);
    }

    void ResetAllValues()
    {
        NotificationsEnabled = false;
        TermsAccepted = false;
        RequiredCheck = false;
        FullName = "";
        Email = "";
        Age = 0;
        Price = 0m;
        Quantity = 0;
        BirthDate = default;
        EventDate = default;
        Appointment = DateTime.Now;
        MeetingDate = DateTime.Now;
        ReminderTime = DateTime.Now;
        SelectedCountry = null;
        SelectedPerson = null;
        SelectedSkills = Array.Empty<string>();
        SelectedTechnologies = Array.Empty<string>();
        StateHasChanged();
    }
}