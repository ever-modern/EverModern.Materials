@using DestallMaterials.Blazor.Components.Inputs

@page "/"

<PageTitle>Component Demo</PageTitle>

<div style="padding: 40px; max-width: 1000px; margin: 0 auto;">
    <h1 style="margin-bottom: 30px; font-size: 28px; font-weight: bold;">DestallMaterials Components Demo</h1>

    <!-- Flag Component -->
    <section style="margin-bottom: 40px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">Flag (Checkbox)</h2>
        <Flag Value="Checked" OnValueChanged="v => Checked = v" Label="Accept terms and conditions" />
        <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
            Checkbox value: <strong>@_checked</strong>
        </p>
    </section>

    <!-- StringInput Component -->
    <section style="margin-bottom: 40px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">StringInput</h2>
        <StringInput Value="@_stringValue" OnValueChanged="v => _stringValue = v" Label="Enter your name" />
        <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
            String value: <strong>@_stringValue</strong>
        </p>
    </section>

    <!-- NumberInput Component -->
    <section style="margin-bottom: 40px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">NumberInput</h2>
        <div style="display: flex; gap: 20px;">
            <div style="flex: 1;">
                <NumberInput T="int" Value="@_intValue" OnValueChanged="v => _intValue = v" Label="Enter an integer" />
                <p style="margin-top: 10px; font-size: 14px; color: #6b7280;">
                    Integer value: <strong>@_intValue</strong>
                </p>
            </div>
            <div style="flex: 1;">
                <NumberInput T="double" Value="@_doubleValue" OnValueChanged="v => _doubleValue = v" Label="Enter a decimal" Accuracy="2" />
                <p style="margin-top: 10px; font-size: 14px; color: #6b7280;">
                    Double value: <strong>@_doubleValue</strong>
                </p>
            </div>
        </div>
    </section>

    <!-- FlexibleDatePicker Component -->
    <section style="margin-bottom: 40px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">FlexibleDatePicker</h2>
        <FlexibleDatePicker Value="@_dateValue" OnValueChanged="v => _dateValue = v" Label="Select a date" Clearable="true" />
        <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
            Date value: <strong>@_dateValue.ToString("yyyy-MM-dd")</strong>
        </p>
    </section>

    <!-- DateTimeInput Component -->
    <section style="margin-bottom: 40px;">
        <h2 style="font-size: 20px; font-weight: 600; margin-bottom: 15px;">DateTimeInput</h2>
        <DateTimeInput Value="@_dateTimeValue" OnValueChanged="v => _dateTimeValue = v" Label="Select date and time" />
        <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
            DateTime value: <strong>@_dateTimeValue.ToString("yyyy-MM-dd HH:mm")</strong>
        </p>
    </section>
</div>

@code {
    // Flag
    public bool Checked
    {
        get => _checked;
        set
        {
            Console.WriteLine($"new value is {value}");
            _checked = value;
        }
    }
    private bool _checked = true;

    // StringInput
    private string _stringValue = "Hello World";

    // NumberInput
    private int _intValue = 42;
    private double _doubleValue = 3.14;

    // FlexibleDatePicker
    private DateOnly _dateValue = DateOnly.FromDateTime(DateTime.Now);

    // DateTimeInput
    private DateTime _dateTimeValue = DateTime.Now;
}