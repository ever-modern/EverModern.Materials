@using DestallMaterials.Blazor.Components.Inputs

@page "/"


<PageTitle>Index</PageTitle>

<div style="padding: 40px; max-width: 800px; margin: 0 auto;">
    <Flag @bind-Value="_checked" Label="Accept terms and conditions" />
    <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
        First checkbox value: <strong>@_checked</strong>
    </p>
</div>

@code {
    public bool Checked
    {
        get => _checked; set
        {
            Console.WriteLine($"new valus is {value}");
            _checked = value;
        }
    }
    private bool _checked = false;

}