@using DestallMaterials.Blazor.Components.Universal.Inputs

@page "/"


<PageTitle>Index</PageTitle>

<div style="padding: 40px; max-width: 800px; margin: 0 auto;">
    <h1>Flag Component Demo</h1>
    <p style="color: #6b7280; margin-bottom: 30px;">Custom checkbox implementation without MudBlazor</p>

    <div style="display: flex; flex-direction: column; gap: 20px;">
        <section style="background: #f9fafb; padding: 20px; border-radius: 8px;">
            <h2 style="font-size: 18px; margin-bottom: 15px;">Basic Usage</h2>
            <Flag @bind-Value="isChecked1" Label="Accept terms and conditions" />
            <Flag @bind-Value="isChecked2" Label="Subscribe to newsletter" />
            <Flag @bind-Value="isChecked3" Label="Enable notifications" />
            <p style="margin-top: 15px; font-size: 14px; color: #6b7280;">
                First checkbox value: <strong>@isChecked1</strong>
            </p>
        </section>

        <section style="background: #f9fafb; padding: 20px; border-radius: 8px;">
            <h2 style="font-size: 18px; margin-bottom: 15px;">Disabled States</h2>
            <Flag @bind-Value="isChecked4" Label="Disabled unchecked" Disabled="true" />
            <Flag @bind-Value="isChecked5" Label="Disabled checked" Disabled="true" />
        </section>

        <section style="background: #f9fafb; padding: 20px; border-radius: 8px;">
            <h2 style="font-size: 18px; margin-bottom: 15px;">Without Labels</h2>
            <div style="display: flex; gap: 15px; align-items: center;">
                <Flag @bind-Value="isChecked6" />
                <Flag @bind-Value="isChecked7" />
                <Flag @bind-Value="isChecked8" />
            </div>
        </section>

        <section style="background: #f9fafb; padding: 20px; border-radius: 8px;">
            <h2 style="font-size: 18px; margin-bottom: 15px;">With Custom CSS Class</h2>
            <Flag @bind-Value="isChecked9" Label="Custom styled checkbox" Class="custom-flag" />
        </section>

        <section style="background: #f9fafb; padding: 20px; border-radius: 8px;">
            <h2 style="font-size: 18px; margin-bottom: 15px;">Interactive Example</h2>
            <Flag @bind-Value="isChecked10" 
                  Label="Check me to see the effect" 
                  OnValueSet="HandleValueChange" />
            @if (showMessage)
            {
                <div style="margin-top: 10px; padding: 10px; background: #dbeafe; border-left: 4px solid #3b82f6; border-radius: 4px;">
                    <p style="margin: 0; color: #1e40af;">Checkbox was @(isChecked10 ? "checked" : "unchecked")!</p>
                </div>
            }
        </section>
    </div>
</div>

@code {
    private bool isChecked1 = false;
    private bool isChecked2 = true;
    private bool isChecked3 = false;
    private bool isChecked4 = false;
    private bool isChecked5 = true;
    private bool isChecked6 = false;
    private bool isChecked7 = true;
    private bool isChecked8 = false;
    private bool isChecked9 = false;
    private bool isChecked10 = false;
    private bool showMessage = false;

    private void HandleValueChange(bool value)
    {
        showMessage = true;
        StateHasChanged();
    }
}